{
  "name": "cosurf",
  "version": "0.1.0",
  "private": true,
  "description": "CoSurf（伴游）- AI 阅读伴侣，读过的，都算数。",
  "license": "MIT",
  "author": "CoSurf Team",
  "homepage": "https://github.com/cosurf/cosurf",
  "main": "out/main/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/cosurf/cosurf.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "dev:full": "powershell -ExecutionPolicy Bypass -File scripts/dev.ps1",
    "build": "electron-vite build",
    "build:release": "electron-vite build && electron-builder",
    "build:native": "cd native && napi build --platform --release",
    "build:native:debug": "cd native && napi build --platform",
    "lint": "pnpm --filter @cosurf/web lint",
    "typecheck": "pnpm --filter @cosurf/web typecheck",
    "check": "powershell -ExecutionPolicy Bypass -File scripts/check.ps1",
    "test": "pnpm -r test",
    "playwright:dev": "pnpm --filter @cosurf/playwright-service dev",
    "clean": "rimraf node_modules dist target out",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.0",
    "rimraf": "^6.0.0",
    "vite": "^6.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
